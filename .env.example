GEMINI_API_KEY=sk-your-key
LLM_BASE_URL=https://model-api.skyengine.com.cn/v1/chat/completions
LLM_MODEL=qwen3.5-flash

# ASR 配置（本地 MLX）
ASR_BACKEND=mlx
MLX_ASR_MODEL=mlx-community/Qwen3-ASR-0.6B-4bit
MLX_ASR_LANGUAGE=zh

# TTS 配置（本地 MLX）
TTS_BACKEND=mlx_qwen3
MLX_TTS_MODEL_TYPE=vibevoice  # 可选：vibevoice / kokoro / qwen3
MLX_TTS_VIBEVOICE_MODEL=mlx-community/VibeVoice-Realtime-0.5B-4bit
MLX_TTS_KOKORO_MODEL=mlx-community/Kokoro-82M-4bit
MLX_TTS_QWEN3_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-Base-4bit
MLX_TTS_LANGUAGE=zh
MLX_TTS_VOICE=
MLX_TTS_SPEED=1.0

# HF-Mirror 加速（国内用户可选）
# 如果下载模型速度慢，取消下面这行的注释
# HF_ENDPOINT=https://hf-mirror.com

# 可选远端后端（仅在对应 backend 被启用时需要）
# QWEN_ASR_BASE_URL=http://localhost:8001
# FISH_TTS_BASE_URL=http://localhost:8002

AUDIO_SAMPLE_RATE=16000
VAD_START_MS=120
VAD_INTERRUPT_MS=200
TURN_SILENCE_MS=1500
LOG_LEVEL=INFO
