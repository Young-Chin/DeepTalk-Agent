# 必需：LLM API 配置
GEMINI_API_KEY=sk-your-key
LLM_BASE_URL=https://model-api.skyengine.com.cn/v1/chat/completions
LLM_MODEL=qwen3.5-flash

# ASR 配置（本地 MLX 离线模型）
ASR_BACKEND=mlx
MLX_ASR_MODEL=mlx-community/whisper-small-asr-4bit
MLX_ASR_LANGUAGE=zh

# TTS 配置（本地 MLX 离线模型）
TTS_BACKEND=mlx_qwen3
MLX_TTS_MODEL_TYPE=kokoro

